# Server
PORT=3001

# MySQL Database (same credentials you give Zapier)
DB_HOST=localhost
DB_PORT=3306
DB_USER=crmpusher_user
DB_PASSWORD=yourpassword
DB_NAME=crmpusher

# Auth
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Default admin credentials (used during setup)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!

# Lead poller interval (seconds) - how often to check for new leads to forward
POLL_INTERVAL_SECONDS=30
